---
const {
  url = '#',
  title = 'Project',
  tags = [],
  description = 'Description',
  video = '',
} = Astro.props;
---

<a
  href={url}
  class="project-card"
>
  <h3>{title}</h3>
  {video && (
    <video 
      width="100%" 
      controls 
      autoplay 
      loop 
      muted 
      style="border-radius: 8px; margin-bottom: 0.5rem;"
    >
      <source src={video} type="video/mp4" />
      Your browser does not support the video tag.
    </video>
  )}
  <span class="card-tags">
    {tags.map((tag) => <span>{tag}</span>)}
  </span>
  <p>{description}</p>
</a>

<style lang="scss">
  .project-card {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background-color: rgba(var(--support-color-dark), 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 1.5rem 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1.5rem;
    text-decoration: none;
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project-card:hover,
  .project-card:focus {
    background: linear-gradient(
          rgb(var(--support-color-darkest)),
          rgb(var(--support-color-darkest))
        )
        padding-box,
      linear-gradient(
          to left,
          rgb(var(--primary-color)),
          rgb(var(--secondary-color))
        )
        border-box;
    border-color: rgba(var(--secondary-color), 0.5);
    transform: translateY(-0.8rem) scale(1.02);
    box-shadow: 0 12px 40px 0 rgba(var(--primary-color), 0.3);

    h3 {
      text-decoration: none;
    }
  }

  .project-card > h3 {
    font-size: 1.4rem;
    text-decoration: underline;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.75rem;

    > * {
      padding: 0 0.5rem;
      border-radius: 6px;
      color: var(--neutral-900);
      background-color: rgb(var(--secondary-color));
      font-weight: bold;
    }
  }

  .project-card p {
    font-size: 1rem;
    line-height: 1.5rem;
    text-wrap: balance;
  }
</style>
