---
import SocialCard from '../components/SocialCard.astro';
---

<section>
  <div
    class="section-divider"
    aria-hidden="true"
  >
    Socials
  </div>
  <div class="container">
    <h2 class="animate">
      <span lang="en">Let's connect</span>
    </h2>
    <div class="socials animate">
      <SocialCard
        url="https://github.com/vbhole21"
        icon="mdi:github"
        platform="GitHub"
        username="VaibhavBhole"
      />
      <SocialCard
        url="https://www.linkedin.com/in/vaibhav-bhole-6a1b4424a?utm_source=share_via&utm_content=profile&utm_medium=member_ios"
        icon="mdi:linkedin"
        platform="LinkedIn"
        username="Vaibhav Bhole"
      />
      <SocialCard
        url="mailto:vbhole12@gmail.com"
        icon="mdi:email"
        platform="Email"
        username="vbhole12@gmail.com"
      />
    </div>
  </div>
</section>

<style lang="scss">
  @use '../assets/scss/base/breakpoint' as *;

  section h2 {
    margin-bottom: 8rem;
  }

  .socials {
    position: relative;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    background-color: #1c1c1c;
    padding: 7rem 1rem;
    border-radius: 1rem;

    @include breakpoint(medium) {
      padding: 7rem 3rem;
    }

    &::before,
    &::after {
      content: '';
      position: absolute;
      width: 540px;
      height: 108px;
      background-size: 100%;
      background-repeat: no-repeat;
      z-index: 1;
    }

    &::before {
      top: -42px;
      left: -90px;
      background-image: url('/dotgrid-upper-socials.png');
    }

    &::after {
      bottom: -43px;
      right: -90px;
      background-image: url('/dotgrid-lower-socials.png');
    }
  }
</style>
